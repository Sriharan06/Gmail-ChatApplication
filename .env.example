# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Real Email Delivery configuration variables:
# 1. Resend API (recommended)
RESEND_API_KEY=""

# 2. Or Standard SMTP server credentials (fallback)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Secure link HMAC crypt secret for email notifications
LINK_SECRET="gmail_chat_dynamic_link_secret_key"

# Optional: Firebase Service Account credentials (JSON string).
# Used to enable Firebase Firestore sync instead of the db.json fallback on localhost.
# Example: FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", "project_id": "...", ...}'
FIREBASE_SERVICE_ACCOUNT=""

